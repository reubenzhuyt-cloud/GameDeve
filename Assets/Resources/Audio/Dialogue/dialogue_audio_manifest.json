        "actor_name": "Player",
        "filename": "StoneTabletDialogue_node1.wav"
      }
    ],
    "file_name": "StoneTabletDialogue",
    "dialogue_name": "神秘石碑对话"
  },
  {
    "audio_files": [
      {
        "node_id": 0,
        "actor_id": 2,
        "text": "......谢谢你......那温暖的光芒......让我想起了生前......",
        "actor_name": "WeakSoul",
        "filename": "WeakSoulDialogue_node0.wav"
      },
      {
        "node_id": 1,
        "actor_id": 0,
        "text": "你是谁？为什么会在这里徘徊？",
        "actor_name": "Player",
        "filename": "WeakSoulDialogue_node1.wav"
      },
      {
        "node_id": 2,
        "actor_id": 2,
        "text": "我......我已经不记得自己的名字了......只记得......饥饿......无尽的饥饿......",
        "actor_name": "WeakSoul",
        "filename": "WeakSoulDialogue_node2.wav"
      },
      {
        "node_id": 3,
        "actor_id": 2,
        "text": "你的光芒让我感到安宁......我想......我可以安心地离去了......",
        "actor_name": "WeakSoul",
        "filename": "WeakSoulDialogue_node3.wav"
      },
      {
        "node_id": 5,
        "actor_id": 2,
        "text": "谢谢你......引魂之人......愿你的光芒照亮更多迷失的灵魂......",
        "actor_name": "WeakSoul",
        "filename": "WeakSoulDialogue_node5.wav"
      },
      {
        "node_id": 6,
        "actor_id": 2,
        "text": "你有一颗善良的心......愿孟婆大人的指引与你同在......",
